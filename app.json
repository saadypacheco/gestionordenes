{
  "expo": {
    "name": "Gestión de Órdenes",
    "slug": "gestion-ordenes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gestionordenes",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gestionordenes.app",
      "deploymentTarget": "15.1"
    },
    "android": {
      "package": "com.gestionordenes.app",
      "versionCode": 1,
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "backgroundColor": "#1E40AF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1E40AF",
          "dark": {
            "backgroundColor": "#0F172A"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "La app necesita la cámara para tomar fotos de la instalación y escanear códigos de barras de equipos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "La app registra la ubicación al cerrar una orden para dejar constancia del lugar de instalación."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "networkSecurityConfig": "./assets/network_security_config.xml"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiUrl": "http://alerthor.net:8777/api",
      "eas": {
        "projectId": "06282507-b59d-49b6-8eed-437013c40bf0"
      },
      "router": {}
    },
    "owner": "saadypacheco"
  }
}
