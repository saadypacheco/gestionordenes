{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "app.config.ts",
    "drizzle.config.ts"
  ],
  "exclude": [
    "node_modules",
    "ordenes20210128",
    "ios",
    "android",
    "dist",
    ".expo"
  ]
}
